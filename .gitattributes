# Normalize line endings — prevents Windows/Linux/Mac CRLF chaos on Hostinger
* text=auto eol=lf

# Force text for source files
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.xml   text eol=lf
*.svg   text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
.htaccess text eol=lf

# Binary files
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.pdf   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.zip   binary
