# ============================================================
# CHATWITHPDFAI.COM — Apache .htaccess for Hostinger
# Force HTTPS, clean URLs, custom error pages, gzip, caching,
# and basic security headers.
# ============================================================

# -- Default document -----------------------------------------
DirectoryIndex landing.html index.html

# -- Disable directory listing --------------------------------
Options -Indexes

# -- Follow symlinks (required by mod_rewrite) ---------------
Options +FollowSymLinks

# ============================================================
# REWRITE ENGINE
# ============================================================
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Force HTTPS — Hostinger SSL is already enabled
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Force non-www (redirect www.chatwithpdfai.com -> chatwithpdfai.com)
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

  # Clean URLs: /pricing -> /pricing.html (but skip real files/dirs)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} !\.[a-zA-Z0-9]{2,5}$
  RewriteRule ^([^/]+)/?$ $1.html [L]

  # Nested clean URLs: /blog/post -> /blog/post.html
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} !\.[a-zA-Z0-9]{2,5}$
  RewriteRule ^(.+)/?$ $1.html [L]

  # Strip trailing .html from URLs already shown in browser
  RewriteCond %{THE_REQUEST} \s/+([^\s]+?)\.html[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L]
</IfModule>

# ============================================================
# CUSTOM ERROR PAGES
# ============================================================
ErrorDocument 403 /403.html
ErrorDocument 404 /404.html
ErrorDocument 500 /500.html

# ============================================================
# GZIP COMPRESSION
# ============================================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript
  AddOutputFilterByType DEFLATE application/json application/xml application/rss+xml
  AddOutputFilterByType DEFLATE image/svg+xml application/vnd.ms-fontobject
  AddOutputFilterByType DEFLATE application/x-font-ttf font/opentype
</IfModule>

# ============================================================
# BROWSER CACHING
# ============================================================
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault                              "access plus 1 month"

  # HTML — short cache (so deploys propagate quickly)
  ExpiresByType text/html                     "access plus 5 minutes"

  # CSS / JS — 1 month (versioned via deploy)
  ExpiresByType text/css                      "access plus 1 month"
  ExpiresByType application/javascript        "access plus 1 month"
  ExpiresByType text/javascript               "access plus 1 month"

  # Images / fonts — 1 year
  ExpiresByType image/svg+xml                 "access plus 1 year"
  ExpiresByType image/png                     "access plus 1 year"
  ExpiresByType image/jpg                     "access plus 1 year"
  ExpiresByType image/jpeg                    "access plus 1 year"
  ExpiresByType image/webp                    "access plus 1 year"
  ExpiresByType image/x-icon                  "access plus 1 year"
  ExpiresByType font/woff                     "access plus 1 year"
  ExpiresByType font/woff2                    "access plus 1 year"
</IfModule>

# ============================================================
# SECURITY HEADERS
# ============================================================
<IfModule mod_headers.c>
  Header set X-Content-Type-Options          "nosniff"
  Header set X-Frame-Options                 "SAMEORIGIN"
  Header set Referrer-Policy                 "strict-origin-when-cross-origin"
  Header set Permissions-Policy              "geolocation=(), microphone=(), camera=()"
  Header set Strict-Transport-Security       "max-age=31536000; includeSubDomains" env=HTTPS

  # Remove server signature
  Header unset X-Powered-By
  Header unset Server
</IfModule>

# ============================================================
# MIME TYPES (ensure correct serving)
# ============================================================
<IfModule mod_mime.c>
  AddType application/javascript            .jsx
  AddType image/svg+xml                     .svg
  AddType application/manifest+json         .webmanifest
  AddType application/json                  .json
</IfModule>

# ============================================================
# BLOCK ACCESS TO SENSITIVE FILES
# ============================================================
<FilesMatch "(^\.|\.(env|git|gitignore|gitattributes|md|yml|yaml|log|bak|swp|tmp)$)">
  Require all denied
</FilesMatch>
